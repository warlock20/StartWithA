{% extends "main/_base.html" %}

{% block content %}
<div class="container-fluid mt-4">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1>Research: {{ session.company.name }} ({{ session.company.ticker_symbol }})</h1>
                <p class="text-muted mb-0">Using Checklist: "{{ session.checklist.name }}" • Progress: Item {{
                    current_item_number }} of {{ total_items }}</p>
            </div>
            <div class="d-flex align-items-center">
                {% with btn_class='btn btn-secondary me-2' %}
                    {% include 'components/smart_back_button.html' %}
                {% endwith %}
            </div>
        </div>
    </div>

    <div class="row">
        <main class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-start">
                    <h4 class="mb-0">Question {{ current_item_number }}: {{ current_item.text }}</h4>
                    {% if current_item.description %}
                    <button class="btn btn-sm btn-outline-secondary ms-2" type="button" data-bs-toggle="collapse"
                            data-bs-target="#descriptionCollapse" aria-expanded="false" aria-controls="descriptionCollapse">
                        <i class="bi bi-info-circle"></i> <span class="desc-toggle-text">Show Details</span>
                    </button>
                    {% endif %}
                </div>
                {% if current_item.description %}
                <div class="collapse" id="descriptionCollapse">
                    <div class="card-body py-2 bg-light border-top">
                        <p class="mb-0">{{ current_item.description }}</p>
                    </div>
                </div>
                {% endif %}
                {% if current_item.parent %}
                <div class="card-body py-2">
                    <p class="text-muted mb-0">Sub-item of: {{ current_item.parent.text }}</p>
                </div>
                {% endif %}
            </div>


            <!-- Unified AI Research Assistant -->
            <div class="accordion mb-4" id="aiResearchAccordion">
                <div class="accordion-item border-primary">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#collapseAIResearch">
                            <i class="bi bi-robot me-2"></i> <strong>AI Research Assistant</strong>
                            <span class="badge bg-primary ms-2">{% if current_item.llm_prompt %}4{% else %}3{% endif %} AI Tools Available</span>
                        </button>
                    </h2>
                    <div id="collapseAIResearch" class="accordion-collapse collapse" data-bs-parent="#aiResearchAccordion">
                        <div class="accordion-body">
                            <p class="text-muted mb-3">
                                <i class="bi bi-lightbulb me-1"></i>
                                Use AI to strengthen your analysis, challenge your reasoning, or extract insights from documents
                            </p>

                            <!-- AI Modes Grid -->
                            <div class="row g-3 mb-3">
                                <!-- Challenge Mode -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="card h-100 ai-mode-card border-danger" style="cursor: pointer;" onclick="triggerAIMode('challenge')">
                                        <div class="card-body text-center p-3">
                                            <div class="mb-2">
                                                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 2rem;"></i>
                                            </div>
                                            <h6 class="mb-1">Challenge</h6>
                                            <span class="badge bg-success mb-2" style="font-size: 0.7rem;">NEW</span>
                                            <p class="small text-muted mb-0">Get counter-arguments to test your reasoning</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Elaboration Mode -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="card h-100 ai-mode-card border-primary" style="cursor: pointer;" onclick="triggerAIMode('elaboration')">
                                        <div class="card-body text-center p-3">
                                            <div class="mb-2">
                                                <i class="bi bi-question-circle text-primary" style="font-size: 2rem;"></i>
                                            </div>
                                            <h6 class="mb-1">Elaboration</h6>
                                            <span class="badge bg-success mb-2" style="font-size: 0.7rem;">NEW</span>
                                            <p class="small text-muted mb-0">Get follow-up questions to deepen analysis</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Fact-Check Mode -->
                                <div class="col-md-6 col-lg-3">
                                    <div class="card h-100 ai-mode-card border-warning" style="cursor: pointer;" onclick="triggerAIMode('factcheck')">
                                        <div class="card-body text-center p-3">
                                            <div class="mb-2">
                                                <i class="bi bi-shield-check text-warning" style="font-size: 2rem;"></i>
                                            </div>
                                            <h6 class="mb-1">Fact-Check</h6>
                                            <span class="badge bg-success mb-2" style="font-size: 0.7rem;">NEW</span>
                                            <p class="small text-muted mb-0">Verify claims and request evidence</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Document Analysis (if available) -->
                                {% if current_item.llm_prompt %}
                                <div class="col-md-6 col-lg-3">
                                    <div class="card h-100 ai-mode-card border-secondary disabled">
                                        <div class="card-body text-center p-3">
                                            <div class="mb-2">
                                                <i class="bi bi-file-earmark-text text-secondary" style="font-size: 2rem;"></i>
                                            </div>
                                            <h6 class="mb-1">Document Analysis</h6>
                                            <span class="badge bg-secondary mb-2" style="font-size: 0.7rem;">COMING SOON</span>
                                            <p class="small text-muted mb-0">Extract insights from uploaded documents</p>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            </div>

                            <!-- AI Response Area (initially hidden) -->
                            <div id="aiResponseArea" style="display: none;">
                                <!-- Loading spinner -->
                                <div id="aiLoadingSpinner" class="text-center py-4" style="display: none;">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2 text-muted">AI is thinking...</p>
                                </div>

                                <!-- Challenge Response -->
                                <div id="aiResponseChallenge" class="ai-response-content" style="display: none;">
                                    <div class="alert alert-danger border-start border-danger border-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-exclamation-diamond me-2" style="font-size: 1.5rem;"></i>
                                            <strong>Challenge Mode</strong>
                                        </div>
                                        <div id="aiResponseChallengeText"></div>
                                    </div>
                                    <div class="ai-feedback-buttons"></div>
                                </div>

                                <!-- Elaboration Response -->
                                <div id="aiResponseElaboration" class="ai-response-content" style="display: none;">
                                    <div class="alert alert-primary border-start border-primary border-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-chat-dots me-2" style="font-size: 1.5rem;"></i>
                                            <strong>Elaboration Mode</strong>
                                        </div>
                                        <div id="aiResponseElaborationText"></div>
                                    </div>
                                    <div class="ai-feedback-buttons d-flex gap-2 justify-content-end mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="submitFeedback('helpful')">
                                            <i class="bi bi-hand-thumbs-up me-1"></i> Helpful
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitFeedback('not_helpful')">
                                            <i class="bi bi-hand-thumbs-down me-1"></i> Not Helpful
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="dismissAI()">
                                            <i class="bi bi-x-lg me-1"></i> Dismiss
                                        </button>
                                    </div>
                                </div>

                                <!-- Fact-Check Response -->
                                <div id="aiResponseFactcheck" class="ai-response-content" style="display: none;">
                                    <div class="alert alert-warning border-start border-warning border-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-shield-exclamation me-2" style="font-size: 1.5rem;"></i>
                                            <strong>Fact-Check Mode</strong>
                                        </div>
                                        <div id="aiResponseFactcheckText"></div>
                                    </div>
                                    <div class="ai-feedback-buttons"></div>
                                </div>

                                <!-- Document Analysis Response -->
                                {% if current_item.llm_prompt %}
                                <div id="aiResponseDocuments" class="ai-response-content" style="display: none;">
                                    <div class="border rounded p-3" style="background: #f8f9fa;">
                                        <h6 class="mb-3"><i class="bi bi-files me-2"></i>Document Analysis</h6>

                                        <p class="text-muted small mb-2">Select documents to analyze with the question prompt:</p>
                                        <div class="document-list border rounded p-2 mb-3" style="max-height: 150px; overflow-y: auto; background: white;">
                                            {% if company_documents %}
                                            {% for doc in company_documents %}
                                            <div class="form-check">
                                                <input class="form-check-input doc-checkbox" type="checkbox" id="doc{{ doc.id }}" value="{{ doc.id }}" checked>
                                                <label class="form-check-label small" for="doc{{ doc.id }}">
                                                    {{ doc.document_title or doc.original_filename }}
                                                </label>
                                            </div>
                                            {% endfor %}
                                            {% else %}
                                            <div class="text-muted small">No documents uploaded yet</div>
                                            {% endif %}
                                        </div>

                                        <div class="alert alert-light mb-2">
                                            <small><strong>AI Prompt:</strong> <em>{{ current_item.llm_prompt }}</em></small>
                                        </div>

                                        <button class="btn btn-secondary btn-sm" onclick="runDocumentAnalysis()">
                                            <i class="bi bi-robot"></i> Run Document Analysis
                                        </button>

                                        <div id="documentAnalysisResult" class="mt-3" style="display: none;"></div>
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Your Answer & Synthesis</h5>
                </div>
                <div class="card-body">
                    <form method="POST" id="answerForm"
                        action="{{ url_for('research.research_step', analysis_id=session.id, item_id=current_item.id) }}">
                        <div class="mb-3">
                            <label for="answer_text" class="form-label">Synthesize your findings, incorporating your
                                research and insights.</label>
                            <!-- BlockNote Editor Container -->
                            <div id="answerEditor" class="blocknote-editor-wrapper border rounded"></div>
                            <!-- Hidden textarea for form submission -->
                            <textarea class="form-control d-none" id="answer_text" name="answer_text" rows="12"
                                placeholder="Start writing your analysis...">{{ answer.answer_text if answer else '' }}</textarea>
                        </div>
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <label for="satisfaction_status" class="form-label">Status for this item:</label>
                                <select id="satisfaction_status" name="satisfaction_status" class="form-select">
                                    <option value="neutral" {% if not answer or not answer.satisfaction_status or
                                        answer.satisfaction_status=='neutral' %}selected{% endif %}>Neutral /
                                        Informational</option>
                                    <option value="satisfied" {% if answer and answer.satisfaction_status=='satisfied'
                                        %}selected{% endif %}>✅ Satisfied / Met</option>
                                    <option value="not_satisfied" {% if answer and
                                        answer.satisfaction_status=='not_satisfied' %}selected{% endif %}>❌ Not
                                        Satisfied / Not Met</option>
                                    <option value="needs_attention" {% if answer and
                                        answer.satisfaction_status=='needs_attention' %}selected{% endif %}>⚠️ Needs
                                        Attention</option>
                                </select>
                            </div>
                            <div class="col-md-6 text-end">
                                {% if previous_item_id %}
                                <a href="{{ url_for('research.research_step', analysis_id=session.id, item_id=previous_item_id) }}"
                                    class="btn btn-secondary">← Previous Item</a>
                                {% endif %}
                                <button type="submit" class="btn btn-success">Save and Next →</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </main>

        <aside class="col-lg-4 context-sidebar">
            <div class="sticky-top">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">{{ session.company.name }} ({{ session.company.ticker_symbol }})</h5>
                        {% if session.company.sector %}
                        <p class="card-text text-muted">{{ session.company.sector.display_name }}</p>
                        {% endif %}
                        <p><strong>Research Status:</strong> <span class="badge bg-info">In Progress</span></p>
                        <div class="progress" style="height: 25px;">
                            <div class="progress-bar bg-primary" role="progressbar"
                                style="width: {{ progress_percent }}%;" aria-valuenow="{{ progress_percent }}"
                                aria-valuemin="0" aria-valuemax="100">
                                Progress: {{ progress_percent|round(2) }}%
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6><i class="bi bi-files"></i> Relevant Documents</h6>
                    </div>
                    <ul class="list-group list-group-flush">
                        {% if company_documents %}
                        {% for doc in company_documents %}
                        <a href="{{ url_for('companies.serve_company_document', filepath=doc.stored_filename) }}"
                            class="list-group-item list-group-item-action" target="_blank">
                            {{ doc.document_title or doc.original_filename }}
                        </a>
                        {% endfor %}
                        {% else %}
                        <div class="list-group-item text-muted">
                            <i class="bi bi-info-circle"></i> No documents uploaded yet
                        </div>
                        {% endif %}
                        <a href="{{ url_for('companies.company_dashboard', company_id=session.company.id) }}"
                            class="list-group-item list-group-item-action text-primary">
                            <i class="bi bi-plus-circle"></i> Upload New Document
                        </a>
                    </ul>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6><i class="bi bi-lightning-charge"></i> Quick Actions</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="{{ url_for('research.view_checklist_session_summary', analysis_id=session.id) }}"
                                class="btn btn-primary btn-sm">
                                <i class="bi bi-clipboard-data"></i> Session Summary
                            </a>
                            <button class="btn btn-outline-primary btn-sm" onclick="performSearch()"
                                title="Smart Search (Ctrl+S)">
                                <i class="bi bi-search"></i> Smart Search
                            </button>
                            <button class="btn btn-outline-primary btn-sm" onclick="searchFinancials()">
                                <i class="bi bi-graph-up"></i> Financial Data
                            </button>
                            <button class="btn btn-outline-primary btn-sm" onclick="searchNews()">
                                <i class="bi bi-newspaper"></i> Latest News
                            </button>
                            <a href="{{ url_for('journal_enhanced.knowledge_hub', company_id=session.company.id) }}"
                                class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-journal-text"></i> View Journal Entries
                            </a>
                            <a href="{{ url_for('journal_enhanced.new_entry', company_id=session.company.id) }}"
                                class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-journal-plus"></i> New Journal Entry
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="{{ url_for('static', filename='js/research_interactions.js') }}" defer></script>
<script src="{{ url_for('static', filename='js/ai-research-assistant.js') }}"></script>

<!-- BlockNote Editor -->
{% include 'components/blocknote_editor_include.html' %}
<script>
    // Main answer editor instance
    let answerEditorRoot = null;

    document.addEventListener('DOMContentLoaded', function () {
        // Set progress bar width from data attribute
        const progressFill = document.querySelector('.progress-fill');
        if (progressFill) {
            const progress = progressFill.getAttribute('data-progress');
            progressFill.style.width = progress + '%';
        }

        // Toggle description button text
        const descCollapse = document.getElementById('descriptionCollapse');
        if (descCollapse) {
            descCollapse.addEventListener('shown.bs.collapse', function () {
                document.querySelector('.desc-toggle-text').textContent = 'Hide Details';
            });
            descCollapse.addEventListener('hidden.bs.collapse', function () {
                document.querySelector('.desc-toggle-text').textContent = 'Show Details';
            });
        }

        // Initialize BlockNote editor
        initializeAnswerEditor();

        // Handle form submission to sync BlockNote content to hidden textarea
        const answerForm = document.getElementById('answerForm');
        if (answerForm) {
            answerForm.addEventListener('submit', function(e) {
                if (window.blockNoteEditorInstance && window.blockNoteEditorInstance.editor) {
                    const blocks = window.blockNoteEditorInstance.editor.document;
                    document.getElementById('answer_text').value = JSON.stringify(blocks);
                }
            });
        }
    });

    function initializeAnswerEditor() {
        try {
            // Check if BlockNote is loaded
            if (!window.initBlockNoteEditor) {
                throw new Error('BlockNote library not loaded');
            }

            // Get existing content from the hidden textarea
            const existingContent = document.getElementById('answer_text').value || '';

            answerEditorRoot = window.initBlockNoteEditor('answerEditor', {
                initialContent: existingContent,
                placeholder: 'Start writing your analysis... Type "/" for commands',
                saveResearchNotesUrl: '{{ url_for("research.autosave_research_answer", analysis_id=session.id, item_id=current_item.id) }}',
                onSave: (data) => {
                    // Update save indicator when auto-save succeeds
                    showSaveIndicator('saved');
                    console.log('Auto-save successful');
                }
            });

            console.log('BlockNote editor initialized with auto-save');

        } catch (error) {
            console.error('Error initializing BlockNote editor:', error);

            // Show the fallback textarea if BlockNote fails
            const editorElement = document.getElementById('answerEditor');
            const textareaElement = document.getElementById('answer_text');
            if (editorElement && textareaElement) {
                editorElement.style.display = 'none';
                textareaElement.classList.remove('d-none');
            }
        }
    }

    // Save indicator function
    function showSaveIndicator(status) {
        // Remove existing indicator if any
        let indicator = document.getElementById('autoSaveIndicator');
        if (!indicator) {
            // Create indicator element
            indicator = document.createElement('div');
            indicator.id = 'autoSaveIndicator';
            document.body.appendChild(indicator);
        }

        // Update indicator based on status
        if (status === 'saving') {
            indicator.innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Saving...';
            indicator.className = 'auto-save-indicator saving';
            indicator.style.opacity = '1';
        } else if (status === 'saved') {
            indicator.innerHTML = '<i class="bi bi-check-circle-fill"></i> Saved';
            indicator.className = 'auto-save-indicator saved';
            indicator.style.opacity = '1';

            // Fade out after 2 seconds
            setTimeout(() => {
                indicator.style.opacity = '0';
            }, 2000);
        } else if (status === 'error') {
            indicator.innerHTML = '<i class="bi bi-exclamation-triangle-fill"></i> Save failed';
            indicator.className = 'auto-save-indicator error';
            indicator.style.opacity = '1';

            // Fade out after 3 seconds
            setTimeout(() => {
                indicator.style.opacity = '0';
            }, 3000);
        }
    }

    // Research Tools Functionality
    const researchTools = {
        savedItems: JSON.parse(localStorage.getItem('research_saved_items_{{ session.id }}') || '[]'),
        notes: JSON.parse(localStorage.getItem('research_notes_{{ session.id }}') || '{}'),
        session: {
            id: {{ session.id }},
            companyName: '{{ session.company.name }}',
            ticker: '{{ session.company.ticker_symbol }}',
            currentItemId: {{ current_item.id }}
        }
    };

    function performSearch() {
        const questionText = document.querySelector('.card-header h4').textContent.trim();
        const searchTerms = `${researchTools.session.companyName} ${researchTools.session.ticker} ${questionText}`;
        const searchUrl = `https://www.google.com/search?q=${encodeURIComponent(searchTerms)}`;
        window.open(searchUrl, '_blank');
        console.log(`Research: Searched for "${searchTerms}"`);
    }

    function searchDocs() {
        const aiSection = document.querySelector('#collapseAI');
        if (aiSection) {
            const collapseElement = new bootstrap.Collapse(aiSection, { show: true });
        } else {
            alert('No document analysis available for this item.');
        }
    }

    function searchFinancials() {
        const ticker = researchTools.session.ticker;
        if (!ticker) {
            alert('No ticker symbol available for financial search.');
            return;
        }

        const sites = [
            `https://finance.yahoo.com/quote/${ticker}`,
            `https://www.sec.gov/edgar/search/#/q=${ticker}`,
            `https://finviz.com/quote.ashx?t=${ticker}`
        ];

        sites.forEach(url => window.open(url, '_blank'));
        console.log(`Research: Opened financial data for ${ticker}`);
    }

    function searchNews() {
        const companyName = researchTools.session.companyName;
        const searchTerms = `${companyName} news`;

        const newsUrls = [
            `https://www.google.com/search?q=${encodeURIComponent(searchTerms)}&tbm=nws`,
            `https://finance.yahoo.com/quote/${researchTools.session.ticker}/news`
        ];

        newsUrls.forEach(url => window.open(url, '_blank'));
        console.log(`Research: Searched news for ${companyName}`);
    }

    // Global variables for BlockNote editor
    let researchEditor = null;
    let currentSources = [];

    function openNotesModal() {
        try {
            console.log('Opening notes modal...');

            const questionText = document.querySelector('.card-header h4').textContent.trim();
            const itemId = researchTools.session.currentItemId;
            const existingNotes = researchTools.notes[itemId] || '';
            const existingSources = researchTools.notes[itemId + '_sources'] || [];
            currentSources = [...existingSources];

            console.log('Modal data:', { questionText, itemId, existingNotes: existingNotes.length, sources: currentSources.length });

            const modalHTML = `
        <div class="modal fade" id="researchNotesModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-journal-text"></i> Research Notes
                            <small class="text-muted ms-2">${questionText}</small>
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="research-editor">
                            <!-- BlockNote Editor Container -->
                            <div id="researchEditorContent" class="blocknote-editor-wrapper border rounded" style="min-height: 350px;"></div>

                            <!-- Source Manager -->
                            <div class="source-manager">
                                <h6 class="mb-2"><i class="bi bi-link"></i> Sources & References</h6>
                                <div class="source-input-group">
                                    <input type="url" class="source-input" id="sourceUrlInput" placeholder="Add source URL (e.g., https://example.com/article)">
                                    <input type="text" class="source-input" id="sourceTitleInput" placeholder="Source title (optional)">
                                    <button type="button" class="source-btn" onclick="addSource()">
                                        <i class="bi bi-plus"></i> Add Source
                                    </button>
                                </div>
                                <div class="sources-list" id="sourcesList"></div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary" onclick="saveResearchNotes()">
                            <i class="bi bi-save"></i> Save Notes
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `;

            const existingModal = document.getElementById('researchNotesModal');
            if (existingModal) existingModal.remove();

            document.body.insertAdjacentHTML('beforeend', modalHTML);

            // Initialize BlockNote editor
            initializeResearchEditor(existingNotes);

            // Render existing sources
            renderSources();

            const modal = new bootstrap.Modal(document.getElementById('researchNotesModal'));
            modal.show();

        } catch (error) {
            console.error('Error opening notes modal:', error);
            showToast('Error opening notes modal. Check console for details.', 'error');
        }
    }

    // Initialize BlockNote editor for research notes modal
    function initializeResearchEditor(existingContent) {
        try {
            console.log('Initializing BlockNote editor...');

            // Check if BlockNote is loaded
            if (!window.initBlockNoteEditor) {
                throw new Error('BlockNote library not loaded');
            }

            // Store editor root reference for cleanup
            researchEditor = window.initBlockNoteEditor('researchEditorContent', {
                initialContent: existingContent || '',
                placeholder: 'Start your research notes here... Type "/" for commands',
                onSave: null // We handle save manually via the Save button
            });

            // Store reference to get content later
            window.researchEditorRoot = researchEditor;

            console.log('BlockNote editor initialized successfully');

        } catch (error) {
            console.error('Error initializing BlockNote editor:', error);

            // Fallback to simple textarea
            const editorElement = document.getElementById('researchEditorContent');
            if (editorElement) {
                editorElement.innerHTML = `
                <textarea class="form-control" rows="15" placeholder="Rich editor failed to load. Using fallback textarea..."
                          id="fallbackTextarea">${existingContent || ''}</textarea>
            `;
            }

            showToast('Rich editor failed to load, using simple text editor', 'warning');
        }
    }

    // Source management functions
    function addSource() {
        const urlInput = document.getElementById('sourceUrlInput');
        const titleInput = document.getElementById('sourceTitleInput');
        const url = urlInput.value.trim();
        const title = titleInput.value.trim();

        if (!url) {
            showToast('Please enter a URL', 'warning');
            return;
        }

        // Auto-fetch title if not provided
        const finalTitle = title || url;

        const source = {
            url: url,
            title: finalTitle,
            timestamp: new Date().toISOString(),
            id: Date.now() // Simple ID generation
        };

        currentSources.push(source);
        urlInput.value = '';
        titleInput.value = '';

        renderSources();
        showToast('Source added successfully', 'success');
    }

    function removeSource(sourceId) {
        currentSources = currentSources.filter(source => source.id !== sourceId);
        renderSources();
        showToast('Source removed', 'info');
    }

    function renderSources() {
        const sourcesList = document.getElementById('sourcesList');
        if (!sourcesList) return;

        if (currentSources.length === 0) {
            sourcesList.innerHTML = '<p class="text-muted small mb-0">No sources added yet</p>';
            return;
        }

        sourcesList.innerHTML = currentSources.map(source => `
        <div class="source-item">
            <a href="${source.url}" target="_blank" class="source-link" title="${source.url}">
                ${source.title}
            </a>
            <button type="button" class="source-remove" onclick="removeSource(${source.id})" title="Remove source">
                ×
            </button>
        </div>
    `).join('');
    }

    function saveResearchNotes() {
        const itemId = researchTools.session.currentItemId;
        let editorContent = '';

        // Try to get content from BlockNote editor first
        if (window.blockNoteEditorInstance && window.blockNoteEditorInstance.editor) {
            // Get JSON content from BlockNote
            const blocks = window.blockNoteEditorInstance.editor.document;
            editorContent = JSON.stringify(blocks);
        } else {
            // Fallback to textarea if BlockNote failed
            const fallbackTextarea = document.getElementById('fallbackTextarea');
            if (fallbackTextarea) {
                editorContent = fallbackTextarea.value;
            } else {
                showToast('No editor content found', 'error');
                return;
            }
        }

        // Save both notes and sources
        researchTools.notes[itemId] = editorContent;
        researchTools.notes[itemId + '_sources'] = currentSources;

        localStorage.setItem('research_notes_{{ session.id }}', JSON.stringify(researchTools.notes));

        const modal = bootstrap.Modal.getInstance(document.getElementById('researchNotesModal'));
        modal.hide();

        showToast('Research notes and sources saved successfully!', 'success');

        // Cleanup BlockNote editor instance
        if (window.researchEditorRoot && window.researchEditorRoot.unmount) {
            window.researchEditorRoot.unmount();
        }
        window.researchEditorRoot = null;
        window.blockNoteEditorInstance = null;
        researchEditor = null;
    }

    function saveLater() {
        const questionText = document.querySelector('.card-header h4').textContent.trim();
        const itemId = researchTools.session.currentItemId;

        const savedItem = {
            itemId: itemId,
            text: questionText,
            timestamp: new Date().toISOString(),
            sessionId: researchTools.session.id,
            company: researchTools.session.companyName
        };

        const existingIndex = researchTools.savedItems.findIndex(item => item.itemId === itemId);
        if (existingIndex >= 0) {
            researchTools.savedItems.splice(existingIndex, 1);
            showToast('Removed from saved items', 'info');
        } else {
            researchTools.savedItems.push(savedItem);
            showToast('Saved for later review', 'success');
        }

        localStorage.setItem('research_saved_items_{{ session.id }}', JSON.stringify(researchTools.savedItems));
        updateSaveLaterButton();
    }

    function updateSaveLaterButton() {
        const button = document.querySelector('[onclick="saveLater()"]');
        if (button) {
            const itemId = researchTools.session.currentItemId;
            const isSaved = researchTools.savedItems.some(item => item.itemId === itemId);
            if (isSaved) {
                button.classList.remove('btn-outline-dark');
                button.classList.add('btn-warning');
                button.innerHTML = '<i class="bi bi-bookmark-fill"></i> Saved <small class="d-block text-muted">Bookmark question</small>';
            } else {
                button.classList.remove('btn-warning');
                button.classList.add('btn-outline-dark');
                button.innerHTML = '<i class="bi bi-bookmark"></i> Save Later <small class="d-block text-muted">Bookmark question</small>';
            }
        }
    }

    function showSavedItems() {
        const savedItems = researchTools.savedItems;
        if (savedItems.length === 0) {
            showToast('No saved items yet. Use the "Save Later" button on questions to bookmark them.', 'info');
            return;
        }

        let modalHTML = `
        <div class="modal fade" id="savedItemsModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-bookmarks"></i> Saved Questions</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">`;

        savedItems.forEach((item, index) => {
            const timestamp = new Date(item.timestamp).toLocaleDateString();
            modalHTML += `
            <div class="list-group-item d-flex justify-content-between align-items-start">
                <div>
                    <h6 class="mb-1">${item.text}</h6>
                    <small class="text-muted">Saved on ${timestamp}</small>
                </div>
                <button class="btn btn-sm btn-outline-danger" onclick="removeSavedItem(${index})">
                    <i class="bi bi-trash"></i>
                </button>
            </div>`;
        });

        modalHTML += `
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>`;

        const existingModal = document.getElementById('savedItemsModal');
        if (existingModal) existingModal.remove();

        document.body.insertAdjacentHTML('beforeend', modalHTML);
        const modal = new bootstrap.Modal(document.getElementById('savedItemsModal'));
        modal.show();
    }

    function removeSavedItem(index) {
        researchTools.savedItems.splice(index, 1);
        localStorage.setItem('research_saved_items_{{ session.id }}', JSON.stringify(researchTools.savedItems));
        showToast('Item removed from saved list', 'info');
        updateSaveLaterButton();

        const modal = bootstrap.Modal.getInstance(document.getElementById('savedItemsModal'));
        modal.hide();
        setTimeout(() => showSavedItems(), 300);
    }


    function showToast(message, type = 'info') {
        let toastContainer = document.getElementById('toast-container');
        if (!toastContainer) {
            toastContainer = document.createElement('div');
            toastContainer.id = 'toast-container';
            toastContainer.className = 'toast-container position-fixed top-0 end-0 p-3';
            toastContainer.style.zIndex = '1055';
            document.body.appendChild(toastContainer);
        }

        const toastId = 'toast-' + Date.now();
        const toastHTML = `
        <div id="${toastId}" class="toast align-items-center text-white bg-${type === 'success' ? 'success' : type === 'info' ? 'info' : 'secondary'} border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    `;

        toastContainer.insertAdjacentHTML('beforeend', toastHTML);
        const toast = new bootstrap.Toast(document.getElementById(toastId));
        toast.show();

        document.getElementById(toastId).addEventListener('hidden.bs.toast', function () {
            this.remove();
        });
    }

    // Enhanced research tools integration
    function captureCurrentPageAsSource() {
        const currentUrl = window.location.href;
        const currentTitle = document.title;

        // Auto-populate source fields if modal is open
        const urlInput = document.getElementById('sourceUrlInput');
        const titleInput = document.getElementById('sourceTitleInput');

        if (urlInput && titleInput) {
            urlInput.value = currentUrl;
            titleInput.value = currentTitle;
            showToast('Current page captured as source', 'info');
        }
    }

    function enhanceResearchTools() {
        // Add source capture to existing research tools
        const originalPerformSearch = window.performSearch;
        window.performSearch = function () {
            originalPerformSearch();
            setTimeout(() => captureCurrentPageAsSource(), 1000);
        };

        const originalSearchNews = window.searchNews;
        window.searchNews = function () {
            originalSearchNews();
            setTimeout(() => captureCurrentPageAsSource(), 1000);
        };

        const originalSearchFinancials = window.searchFinancials;
        window.searchFinancials = function () {
            originalSearchFinancials();
            setTimeout(() => captureCurrentPageAsSource(), 1000);
        };
    }

    // Keyboard shortcuts
    document.addEventListener('keydown', function (e) {
        // Global shortcuts (when not in editor)
        if (e.ctrlKey && !e.target.matches('input, textarea, select, .bn-editor *, .research-content *')) {
            switch (e.key.toLowerCase()) {
                case 's':
                    e.preventDefault();
                    performSearch();
                    break;
                case 'd':
                    e.preventDefault();
                    searchDocs();
                    break;
                case 'r':
                    e.preventDefault();
                    openNotesModal();
                    break;
            }
        }

        // Source input shortcut - Ctrl+Enter to add source
        if (e.ctrlKey && e.key === 'Enter' && document.getElementById('researchNotesModal')) {
            const sourceUrlInput = document.getElementById('sourceUrlInput');
            if (document.activeElement === sourceUrlInput || document.activeElement === document.getElementById('sourceTitleInput')) {
                e.preventDefault();
                addSource();
            }
        }
    });

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function () {
        updateSaveLaterButton();
        enhanceResearchTools();
    });

    // =============================================================================
    // AI Research Assistant - AJAX Interactions
    // =============================================================================

    let currentFeedbackId = null;  // Track current AI response for feedback

    /**
     * Trigger AI mode (Challenge, Elaboration, Fact-Check)
     * Validates answer exists, then calls AI assistant API
     */
    function triggerAIMode(mode) {
        // Get answer text from BlockNote editor
        const answerText = getAnswerTextFromEditor();

        // Validate answer exists
        if (!answerText || answerText.trim().length < 10) {
            alert('Please write at least a few sentences in your answer before using AI assistance.');
            return;
        }

        // Call AI assistant
        callAIAssistant(mode, answerText);
    }

    /**
     * Get answer text from BlockNote editor
     * Extracts plain text from editor by getting DOM textContent
     */
    function getAnswerTextFromEditor() {
        // Try to get text from BlockNote editor container
        const editorContainer = document.getElementById('answerEditor');
        if (editorContainer) {
            // Get text content from the rendered editor
            const text = editorContainer.textContent || editorContainer.innerText || '';
            return text.trim();
        }

        // Fallback to hidden textarea if BlockNote failed to load
        const fallbackTextarea = document.getElementById('answer_text');
        if (fallbackTextarea && fallbackTextarea.value) {
            try {
                // Try to parse JSON blocks and extract text
                const blocks = JSON.parse(fallbackTextarea.value);
                let text = '';
                blocks.forEach(block => {
                    if (block.content && Array.isArray(block.content)) {
                        block.content.forEach(item => {
                            if (item.type === 'text' && item.text) {
                                text += item.text + ' ';
                            }
                        });
                        text += '\n';
                    }
                });
                return text.trim();
            } catch (e) {
                // If not JSON, just return the raw value
                return fallbackTextarea.value.trim();
            }
        }

        console.error('Could not extract text from editor');
        return '';
    }

    /**
     * Call AI Assistant API
     * Makes AJAX POST request to backend
     */
    function callAIAssistant(mode, answerText) {
        // Show loading state
        showAILoading(mode);

        // Get question text
        const questionText = {{ current_item.text|tojson }};

        // Prepare request data
        const requestData = {
            mode: mode,
            question_text: questionText,
            answer_text: answerText,
            analysis_id: {{ session.id }},
            item_id: {{ current_item.id }},
            company_name: {{ session.company.name|tojson }}
        };

        // Make AJAX POST request
        fetch('/research/ai_assist', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(requestData)
        })
        .then(response => response.json())
        .then(data => {
            hideAILoading();

            if (data.success) {
                // Display AI response
                displayAIResponse(mode, data.response, data.feedback_id);
                currentFeedbackId = data.feedback_id;

                // Log success
                console.log(`AI ${mode} success: ${data.tokens_used} tokens used`);
            } else {
                // Show error
                alert('AI Assistant Error: ' + (data.error || 'Unknown error occurred'));
                console.error('AI assist error:', data.error);
            }
        })
        .catch(error => {
            hideAILoading();
            alert('Network error. Please check your connection and try again.');
            console.error('AI assist network error:', error);
        });
    }

    /**
     * Show AI loading spinner with mode-specific message
     */
    function showAILoading(mode) {
        const responseArea = document.getElementById('aiResponseArea');
        const loadingSpinner = document.getElementById('aiLoadingSpinner');

        // Hide all response sections
        document.getElementById('aiResponseChallenge').style.display = 'none';
        document.getElementById('aiResponseElaboration').style.display = 'none';
        document.getElementById('aiResponseFactcheck').style.display = 'none';

        // Update loading message based on mode
        const loadingMessages = {
            'challenge': 'Analyzing your reasoning and preparing counter-arguments...',
            'elaboration': 'Crafting follow-up questions to deepen your analysis...',
            'factcheck': 'Identifying claims that need verification...'
        };

        const loadingText = loadingSpinner.querySelector('p');
        if (loadingText) {
            loadingText.textContent = loadingMessages[mode] || 'Processing...';
        }

        // Show loading spinner and response area
        loadingSpinner.style.display = 'flex';
        responseArea.style.display = 'block';
    }

    /**
     * Hide AI loading spinner
     */
    function hideAILoading() {
        const loadingSpinner = document.getElementById('aiLoadingSpinner');
        loadingSpinner.style.display = 'none';
    }

    /**
     * Create reusable AI feedback buttons
     * Generates HTML for feedback buttons (Helpful, Not Helpful, Dismiss)
     * Can be reused across platform (research, decision journal, portfolio notes, etc.)
     */
    function createAIFeedbackButtons() {
        return `
            <div class="d-flex gap-2 justify-content-end mt-2">
                <button type="button" class="btn btn-sm btn-outline-success" onclick="submitFeedback('helpful')">
                    <i class="bi bi-hand-thumbs-up me-1"></i> Helpful
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="submitFeedback('not_helpful')">
                    <i class="bi bi-hand-thumbs-down me-1"></i> Not Helpful
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="dismissAI()">
                    <i class="bi bi-x-lg me-1"></i> Dismiss
                </button>
            </div>
        `;
    }

    /**
     * Display AI response in appropriate section
     */
    function displayAIResponse(mode, responseText, feedbackId) {
        // Map mode to response section and text container IDs
        const responseSections = {
            'challenge': { section: 'aiResponseChallenge', text: 'aiResponseChallengeText' },
            'elaboration': { section: 'aiResponseElaboration', text: 'aiResponseElaborationText' },
            'factcheck': { section: 'aiResponseFactcheck', text: 'aiResponseFactcheckText' }
        };

        const ids = responseSections[mode];
        if (!ids) {
            console.error('Invalid mode:', mode);
            return;
        }

        const responseSection = document.getElementById(ids.section);
        const contentDiv = document.getElementById(ids.text);

        if (!responseSection || !contentDiv) {
            console.error('Could not find response containers for mode:', mode);
            return;
        }

        // Format and display response
        contentDiv.innerHTML = formatAIResponse(responseText);

        // Add feedback buttons dynamically
        const feedbackContainer = responseSection.querySelector('.ai-feedback-buttons');
        if (feedbackContainer) {
            feedbackContainer.innerHTML = createAIFeedbackButtons();
        }

        // Show response section
        responseSection.style.display = 'block';

        // Store feedback_id in data attribute for feedback buttons
        responseSection.setAttribute('data-feedback-id', feedbackId);
    }

    /**
     * Format AI response text (simple markdown-style formatting)
     * Converts line breaks, bold text, and lists to HTML
     */
    function formatAIResponse(text) {
        // Escape HTML first
        let formatted = text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');

        // Convert **bold** to <strong>
        formatted = formatted.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

        // Convert line breaks to paragraphs
        const paragraphs = formatted.split('\n\n');
        formatted = paragraphs.map(p => {
            // Check if paragraph is a list
            if (p.includes('\n- ') || p.includes('\n* ') || p.match(/^\d+\./m)) {
                // Convert bullet lists
                let listContent = p.replace(/^- /gm, '<li>').replace(/^\* /gm, '<li>');
                // Convert numbered lists
                listContent = listContent.replace(/^\d+\. /gm, '<li>');

                // Wrap in ul or ol
                if (p.match(/^\d+\./m)) {
                    return '<ol>' + listContent.split('\n').map(line => line.startsWith('<li>') ? line + '</li>' : line).join('') + '</ol>';
                } else {
                    return '<ul>' + listContent.split('\n').map(line => line.startsWith('<li>') ? line + '</li>' : line).join('') + '</ul>';
                }
            } else {
                return '<p>' + p.replace(/\n/g, '<br>') + '</p>';
            }
        }).join('');

        return formatted;
    }

    /**
     * Submit feedback for AI response
     */
    function submitFeedback(feedbackValue) {
        if (!currentFeedbackId) {
            console.error('No feedback_id available');
            return;
        }

        // Disable feedback buttons
        const feedbackButtons = document.querySelectorAll('.ai-feedback-buttons .btn');
        feedbackButtons.forEach(btn => btn.disabled = true);

        // Make AJAX POST request
        fetch('/research/ai_assist/feedback', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                feedback_id: currentFeedbackId,
                feedback: feedbackValue
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                console.log('Feedback recorded:', feedbackValue);

                // Show brief confirmation
                const confirmationMsg = feedbackValue === 'helpful'
                    ? 'Thank you for your feedback!'
                    : 'Feedback recorded. We\'ll improve our responses.';

                // You could show a toast notification here
                console.log(confirmationMsg);

                // If not helpful, enable regenerate button
                if (feedbackValue === 'not_helpful') {
                    // Enable regenerate functionality
                    console.log('User can regenerate response');
                }
            } else {
                console.error('Feedback error:', data.error);
                // Re-enable buttons on error
                feedbackButtons.forEach(btn => btn.disabled = false);
            }
        })
        .catch(error => {
            console.error('Feedback network error:', error);
            // Re-enable buttons on error
            feedbackButtons.forEach(btn => btn.disabled = false);
        });
    }

    /**
     * Regenerate AI response
     */
    function regenerateAI() {
        if (!currentFeedbackId) {
            console.error('No feedback_id available for regeneration');
            return;
        }

        // Show loading
        showAILoading('regenerating');

        // Make AJAX POST request
        fetch('/research/ai_assist/regenerate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                feedback_id: currentFeedbackId
            })
        })
        .then(response => response.json())
        .then(data => {
            hideAILoading();

            if (data.success) {
                // Display new AI response
                displayAIResponse(data.mode, data.response, data.feedback_id);
                currentFeedbackId = data.feedback_id;

                console.log('Response regenerated:', data.tokens_used, 'tokens used');
            } else {
                alert('Regeneration Error: ' + (data.error || 'Unknown error occurred'));
                console.error('Regeneration error:', data.error);
            }
        })
        .catch(error => {
            hideAILoading();
            alert('Network error. Please check your connection and try again.');
            console.error('Regeneration network error:', error);
        });
    }

    /**
     * Dismiss AI response area
     */
    function dismissAI() {
        // Submit dismissed feedback
        if (currentFeedbackId) {
            submitFeedback('dismissed');
        }

        // Hide response area
        const responseArea = document.getElementById('aiResponseArea');
        responseArea.style.display = 'none';

        // Hide all response sections
        document.getElementById('aiResponseChallenge').style.display = 'none';
        document.getElementById('aiResponseElaboration').style.display = 'none';
        document.getElementById('aiResponseFactcheck').style.display = 'none';

        // Reset feedback ID
        currentFeedbackId = null;
    }

    /**
     * Run Document Analysis (existing feature - placeholder)
     * TODO: Integrate with existing document analysis functionality
     */
    function runDocumentAnalysis() {
        alert('Document Analysis feature integration coming soon!');
        console.log('Document Analysis triggered');
        // TODO: Call existing document analysis code
    }
</script>

{% endblock %}