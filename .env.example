# =============================================================================
# Investment Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# REQUIRED - Core Settings
# -----------------------------------------------------------------------------
SECRET_KEY='generate-a-strong-random-key-here'
DATABASE_URL='postgresql://user:password@host:5432/database_name'

# -----------------------------------------------------------------------------
# REQUIRED - Auth0 Configuration
# -----------------------------------------------------------------------------
# Get these from Auth0 Dashboard > Applications > Your App > Settings
AUTH0_DOMAIN='your-tenant.auth0.com'
AUTH0_CLIENT_ID='your-client-id'
AUTH0_CLIENT_SECRET='your-client-secret'
AUTH0_CALLBACK_URL='https://your-app.railway.app/auth/callback'
AUTH0_AUDIENCE='https://your-tenant.auth0.com/userinfo'

# -----------------------------------------------------------------------------
# REQUIRED - AI API Keys (at least one)
# -----------------------------------------------------------------------------
GEMINI_API_KEY='your-gemini-api-key'
# OPENAI_API_KEY='your-openai-api-key'
# ANTHROPIC_API_KEY='your-anthropic-api-key'

# -----------------------------------------------------------------------------
# OPTIONAL - Redis (for Celery background tasks)
# -----------------------------------------------------------------------------
# Railway provides this automatically when you add Redis service
REDIS_URL='redis://localhost:6379/0'

# -----------------------------------------------------------------------------
# OPTIONAL - Other Services
# -----------------------------------------------------------------------------
# NEWS_API_KEY='your-newsapi-key'

# -----------------------------------------------------------------------------
# OPTIONAL - Flask Settings
# -----------------------------------------------------------------------------
FLASK_APP='run.py'
FLASK_DEBUG='False'  # Set to 'True' only in development

# -----------------------------------------------------------------------------
# PRODUCTION SETTINGS (Railway sets these automatically)
# -----------------------------------------------------------------------------
# SESSION_COOKIE_SECURE='True'  # Railway handles HTTPS
# UPLOAD_FOLDER='/app/instance/uploads'  # If using Railway Volume
