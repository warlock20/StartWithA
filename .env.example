# =============================================================================
# StartWithA — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose overrides DATABASE_URL and REDIS_URL automatically,
# so you only need to set them here if you're running without Docker.
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
SECRET_KEY='change-me-to-a-random-string'
FLASK_APP='run.py'
FLASK_DEBUG='False'

# -----------------------------------------------------------------------------
# Auth0  (required for production; optional if DEMO_MODE is enabled)
# -----------------------------------------------------------------------------
# 1. Create a free Auth0 tenant at https://auth0.com
# 2. Create a "Regular Web Application"
# 3. Set the Allowed Callback URL to:
#      http://localhost:8000/auth/callback   (Docker)
#      http://localhost:5000/auth/callback   (local flask run)
# 4. Copy the credentials below from Settings
AUTH0_DOMAIN='your-tenant.auth0.com'
AUTH0_CLIENT_ID='your-client-id'
AUTH0_CLIENT_SECRET='your-client-secret'
AUTH0_CALLBACK_URL='http://localhost:8000/auth/callback'
AUTH0_AUDIENCE='https://your-tenant.auth0.com/userinfo'

# Comma-separated emails that get admin access at /admin
ADMIN_EMAILS='you@example.com'

# -----------------------------------------------------------------------------
# AI API Keys  (at least one required for AI features)
# -----------------------------------------------------------------------------
# Gemini is the default provider. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY='your-gemini-api-key'

# Optional alternative providers:
# OPENAI_API_KEY='your-openai-api-key'
# ANTHROPIC_API_KEY='your-anthropic-api-key'

# -----------------------------------------------------------------------------
# Database & Redis  (set automatically by Docker Compose)
# -----------------------------------------------------------------------------
# Only set these if running WITHOUT Docker:
# DATABASE_URL='postgresql://postgres:postgres@localhost:5432/investment_checklist'
# REDIS_URL='redis://localhost:6379/0'

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# DEMO_MODE='true'                        # Seed a demo user for trying the app
# NEWS_API_KEY='your-newsapi-key'        # NewsAPI for market news
# DEFAULT_USER_TIER='amateur'             # Default tier for new users (amateur|pro)
# SESSION_COOKIE_SECURE='False'          # Set True behind HTTPS
# UPLOAD_FOLDER='/app/instance/uploads'  # File upload path
